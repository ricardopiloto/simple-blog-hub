# Copiar para .env.api e .env.bff e preencher (não commitar).
# .env.api — variáveis para o contentor da API
ConnectionStrings__DefaultConnection=Data Source=/data/blog.db
API__InternalKey=seu-valor-secreto-forte-aqui
Admin__Email=admin@exemplo.com
# Obrigatório se autores usarem Geração de Imagem (API Tokens Cloudflare encriptados at-rest)
# 32 bytes em base64 ou 64 caracteres hexadecimais
Cloudflare__EncryptionKey=

# .env.bff — variáveis para o contentor do BFF (API__BaseUrl é definido no compose)
API__InternalKey=seu-valor-secreto-forte-aqui
Jwt__Secret=outra-chave-secreta-min-32-caracteres-produção
# API de integração n8n (não expor ao browser)
INTEGRATIONS__APIKEY=chave-forte-para-n8n
INTEGRATIONS__ADMINAUTHORID=49C95364-A432-4EAD-8AAA-F630F8E70A31
# Geração de capa via OpenRouter (integração n8n)
INTEGRATIONS__OPENROUTER__APIKEY=
INTEGRATIONS__OPENROUTER__IMAGEMODEL=black-forest-labs/flux.2-klein-4b
# Prompt de arte no formulário de post (DeepSeek API directa)
DEEPSEEK__APIKEY=
DEEPSEEK__MODEL=deepseek-chat
